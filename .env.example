# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=contextforge_chunks

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Chunking
CHUNK_TOKENS=512
CHUNK_OVERLAP_TOKENS=200

# Ingestion
INGEST_MAX_CHARS=2000000

# Phase 2 (local RAG)
# Local generator used for classification / HyDE / answer synthesis
LLM_MODEL=google/flan-t5-base
LLM_TASK=text2text-generation
LLM_MAX_NEW_TOKENS=256
LLM_TEMPERATURE=0.7

# Hybrid retrieval
HYBRID_DENSE_TOP_K=50
HYBRID_SPARSE_TOP_K=50
HYBRID_FUSED_TOP_K=20
FINAL_TOP_K=5

# RRF fusion
RRF_K=60
RRF_WEIGHT_DENSE=0.7
RRF_WEIGHT_SPARSE=0.3

# Cross-encoder reranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Faithfulness loop
FAITHFULNESS_THRESHOLD=0.75
FAITHFULNESS_MAX_RETRIES=2
